{
  "name": "omah-monorepo",
  "private": true,
  "workspaces": ["apps/*"],
  "scripts": {
    "desktop": "turbo run tauri:dev --filter=omah-desktop",
    "desktop:build": "turbo run tauri:build --filter=omah-desktop",
    "build": "cargo build --release",
    "check": "cargo check --workspace",
    "test": "cargo test --workspace",
    "lint": "cargo clippy --all-targets -- -D warnings",
    "fmt": "cargo fmt",
    "fmt:check": "cargo fmt --check",
    "cli:install": "bun run build && cp target/release/omah /usr/local/bin/omah",
    "cli:uninstall": "rm -f /usr/local/bin/omah",
    "tag": "VERSION=$(grep -m1 '^version' crates/omah_bin/Cargo.toml | sed 's/.*\"\\(.*\\)\".*/\\1/') && git tag \"v$VERSION\" && git push origin \"v$VERSION\"",
    "hooks": "git config core.hooksPath .githooks",
    "clean": "cargo clean"
  },
  "devDependencies": {
    "turbo": "^2.8.17"
  },
  "packageManager": "bun@1.3.10"
}
