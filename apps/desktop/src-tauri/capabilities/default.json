{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main and about windows",
  "windows": [
    "main",
    "about"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "core:webview:allow-create-webview-window",
    "core:window:allow-set-theme",
    "core:window:allow-theme",
    "shell:default"
  ]
}